{
  "language": "python",
  "test_framework": "pytest",
  "risk": {
    "high_risk_paths": [
      "auth",
      "authentication",
      "permission",
      "access",
      "payment",
      "billing",
      "security",
      "api",
      "db",
      "database"
    ],
    "security_keywords": [
      "token",
      "password",
      "secret",
      "permission",
      "role",
      "auth",
      "jwt",
      "csrf",
      "access"
    ],
    "ignored_path_fragments": [
      ".venv/",
      "venv/",
      "__pycache__/",
      ".git/",
      "node_modules/",
      "dist/",
      "build/",
      ".pytest_cache/",
      "examples/"
    ]
  }
}
